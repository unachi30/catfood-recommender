# 複製為 .env 後修改（勿 commit .env）
# cp .env.example .env

# 你的網域（需已指向伺服器 IP）
APP_DOMAIN=catfood.example.com

# 後端 CORS：允許的前端網址（HTTPS）
APP_CORS_ALLOWED_ORIGINS=https://catfood.example.com

# 資料庫與 JWT（請改成隨機強密碼，至少 32 字元）
MYSQL_ROOT_PASSWORD=change-me-db-password
APP_JWT_SECRET=change-me-jwt-secret-at-least-32-chars-long
